# API base — must end with /api so axios calls append cleanly
# e.g. http://localhost:5000/api  →  /api/faqs → http://localhost:5000/api/faqs
VITE_API_URL=http://localhost:5000/api

# Socket.IO server — must NOT end with /api
# e.g. http://localhost:5000  →  connects to http://localhost:5000 socket server
VITE_SOCKET_URL=http://localhost:5000